# Copy to .env and fill in real keys.  .env is gitignored.
#
# These keys are ONLY needed for external-API baseline runs
# (benchmarks/external/cli.py).  The core SMBoost harness does not require
# them — it defaults to a local llama.cpp OpenAI-compatible server.

# Anthropic — Claude Sonnet 4.6 etc.  See https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o, GPT-4o-mini.  See https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter — used for Llama-3-70B-via-OpenRouter.
# See https://openrouter.ai/keys
OPENROUTER_API_KEY=
