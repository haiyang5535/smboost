# Ignore all markdown files
*.md

# Except README.md, CONTRIBUTING.md, SECURITY.md, and the long-form
# project writeup committed at docs/writeup.md
!README.md
!CONTRIBUTING.md
!SECURITY.md
!docs/writeup.md

# Worktrees
.worktrees/

# Python artifacts
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.egg
.DS_Store
**/.DS_Store
benchmarks/results/

# Frontend — local-only, never committed
frontend/

# Local model weights (GGUF / HF) — never committed
models/
*.gguf

# Ollama Modelfiles — local-only
Modelfile
Modelfile-*

# Logs
*.log
benchmarks/data/*.jsonl

# BFCL downloaded cache (keep .gitkeep so directory is tracked)
benchmarks/bfcl/data/*.jsonl
!benchmarks/bfcl/data/.gitkeep

# GSM8K downloaded cache (keep .gitkeep so directory is tracked)
benchmarks/gsm8k/data/*.jsonl
!benchmarks/gsm8k/data/.gitkeep
